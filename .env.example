# Network
LISTEN_ADDR=:8080
DEX_TOKEN_URL=https://dex.dex.svc.cluster.local/token

# Runtime behavior
HTTP_TIMEOUT=5s
CACHE_CLEANUP_INTERVAL=5m
EXPIRY_SAFETY_MARGIN=30s
SHUTDOWN_TIMEOUT=10s
LOG_LEVEL=INFO

# Cache
CACHE_MAX_ENTRIES=1024

# Security
ALLOW_INSECURE_DEX_URL=false

# Header configuration
UPSTREAM_AUTH_HEADER=Authorization
# Map token response JSON fields to additional response headers.
# Format: json_field:header_name,... (omit :header_name to use field name as header)
# Example: access_token,token_type:X-Token-Type
UPSTREAM_TOKEN_HEADERS=
CLIENT_ID_HEADER=x-client-id
CLIENT_SECRET_HEADER=x-client-secret
SCOPE_HEADER=x-scope

# Optional static credentials mode
# Each STATIC_* variable overrides the corresponding incoming header.
# You can set any combination; unset values are still read from headers.
STATIC_CLIENT_ID=
STATIC_CLIENT_SECRET=
STATIC_SCOPE=

# Optional JWT/JWKS validation gate
# When JWKS_URL is set, incoming requests must carry a valid JWT.
# Requires STATIC_CLIENT_ID and STATIC_CLIENT_SECRET to be set.
JWKS_URL=
JWT_HEADER=Authorization
# Optional: reject tokens not issued by this issuer (iss claim)
JWT_ISSUER=
# Optional: reject tokens not intended for this audience (aud claim)
JWT_AUDIENCE=
